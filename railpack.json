{
  "$schema": "https://schema.railpack.com",
  "packages": {
    "bun": "latest",
    "rust": "1.95.0"
  },
  "steps": {
    "build": {
      "commands": [
        "...",
        "mkdir -p bin && cp target/release/produktive-api bin/produktive-api",
        "cd web && bun install --frozen-lockfile",
        "cd web && bun run build"
      ]
    }
  },
  "deploy": {
    "aptPackages": [
      "ca-certificates"
    ],
    "inputs": [
      "...",
      {
        "step": "build",
        "include": [
          "bin/produktive-api",
          "web/dist/**"
        ]
      }
    ],
    "startCommand": "./bin/produktive-api"
  }
}
