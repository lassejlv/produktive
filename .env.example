# Direct connection — used for migrations only.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/produktive
# Pooled connection (e.g. PgBouncer / Neon pooler) — used by the running app.
# Falls back to DATABASE_URL if unset.
DATABASE_POOLED_URL=postgres://postgres:postgres@localhost:5432/produktive
PORT=3000
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
JWT_TTL_HOURS=720
SCHEDULER_TICK_MS=5000
SCHEDULER_MAX_CONCURRENT_CHECKS=32
SCHEDULER_MAX_DUE_PER_TICK=100
HTTP_CHECK_MAX_BODY_BYTES=1048576
REDIS_URL=redis://127.0.0.1/
LOCAL_REGION_SLUG=eu-west
API_LOCAL_WORKER_ENABLED=true
WORKER_TOKEN=change-me-worker-token
# Comma-separated region-scoped worker tokens for external workers, e.g. `us-east=token-1,ap-south=token-2`.
WORKER_TOKENS=
WORKER_LEASE_SECONDS=30
AUTH_RATE_LIMIT_LOGIN_PER_MINUTE=10
AUTH_RATE_LIMIT_REGISTER_PER_HOUR=5
AUTH_RATE_LIMIT_REGISTER_GLOBAL_PER_HOUR=100
# Password reset: per-email and global request caps (per hour), and how long the emailed link stays valid (minutes).
AUTH_RATE_LIMIT_PASSWORD_RESET_PER_HOUR=5
AUTH_RATE_LIMIT_PASSWORD_RESET_GLOBAL_PER_HOUR=100
PASSWORD_RESET_TTL_MINUTES=60
# Email verification: per-email and global resend caps (per hour), and how long the emailed link stays valid (minutes, default 24h).
AUTH_RATE_LIMIT_EMAIL_VERIFICATION_PER_HOUR=5
AUTH_RATE_LIMIT_EMAIL_VERIFICATION_GLOBAL_PER_HOUR=200
EMAIL_VERIFICATION_TTL_MINUTES=1440
SESSION_CLEANUP_TICK_SECONDS=3600
# Hostname customers CNAME their domain to (Cloudflare for SaaS customer target).
CUSTOM_DOMAIN_CNAME_TARGET=cname.produktive.app
# --- Cloudflare for SaaS (custom hostnames) ---
# When CF_API_TOKEN + CF_ZONE_ID are set, custom domains are registered as
# Cloudflare Custom Hostnames and Cloudflare issues + auto-renews the TLS cert.
# Token needs Zone:SSL and Certificates:Edit (+ DNS:Edit to manage records).
CF_API_TOKEN=
CF_ZONE_ID=
# Optional; defaults to https://api.cloudflare.com/client/v4
CF_BASE_URL=
# Dedicated originless fallback-origin hostname (a proxied AAAA 100:: record).
CF_FALLBACK_ORIGIN=saas-fallback.produktive.app
# Zone DCV-delegation UUID — renders the _acme-challenge CNAME customers add.
CF_DCV_DELEGATION_UUID=
# Comma-separated browser origins allowed to call the API. Leave empty to disable cross-origin browser requests.
CORS_ALLOWED_ORIGINS=http://localhost:5173
# Neon TimescaleDB log event storage (optional — set LOG_DATABASE_URL to enable log ingest/search; leave empty to disable logs).
# Use the direct (non-pooled) connection for migrations; pooled URL for runtime if available.
LOG_DATABASE_URL=
LOG_DATABASE_POOLED_URL=
# Produktive Deployments private preview. Disabled by default; workspace access
# is separately approved by admins.
DEPLOYMENTS_ENABLED=false
# 32-byte hex key for encrypted registry credentials and runtime secrets.
# Example generation: openssl rand -hex 32
DEPLOY_SECRETS_KEY=
DEPLOY_MAX_SERVICES_PER_WORKSPACE=3
DEPLOY_MAX_ACTIVE_DEPLOYMENTS_PER_WORKSPACE=6
FLY_API_TOKEN=
FLY_ORG_SLUG=
FLY_API_HOSTNAME=https://api.machines.dev
FLY_APP_NAME_PREFIX=prd
# Build-from-source (deploy-worker, optional). When DEPOT_TOKEN, DEPOT_PROJECT_ID,
# and FLY_REGISTRY_TOKEN are all set, git-source services are built via Depot and
# pushed to the registry; otherwise only pre-built image deploys work.
DEPOT_TOKEN=
DEPOT_PROJECT_ID=
# Fly registry/deploy token for pushing built images (distinct from FLY_API_TOKEN).
FLY_REGISTRY_TOKEN=
BUILD_REGISTRY_HOST=registry.fly.io
# Google Cloud Run provider (deploy-worker + api, optional). When the service
# account is unset the worker stays Fly-only and the admin provider selector's
# Cloud Run option will fail to deploy. Provider selection is admin-gated.
# Raw service-account key JSON (or use CLOUD_RUN_SERVICE_ACCOUNT_FILE for a path).
CLOUD_RUN_SERVICE_ACCOUNT_JSON=
# CLOUD_RUN_SERVICE_ACCOUNT_FILE=/run/secrets/cloud-run-sa.json
# Defaults to the key's project_id when unset.
CLOUD_RUN_PROJECT_ID=
CLOUD_RUN_APP_NAME_PREFIX=prd
# Artifact Registry base for git-built Cloud Run images (Cloud Run cannot pull
# from the Fly registry). Format: REGION-docker.pkg.dev/PROJECT/REPO
CLOUD_RUN_ARTIFACT_REGISTRY=
DEPLOY_WORKER_POLL_INTERVAL_MS=2000
DEPLOY_RETENTION_CLEANUP_INTERVAL_SECONDS=3600
DEPLOY_RETENTION_DELETE_BATCH_SIZE=5000
DEPLOY_LOG_RETENTION_DAYS=7
DEPLOY_METRIC_RETENTION_DAYS=30
DEPLOY_EVENT_RETENTION_DAYS=90
# Sprites.dev sandboxes (under Deployments). Disabled by default.
SANDBOXES_ENABLED=false
# Preferred: org-scoped Sprites API token from https://sprites.dev/account
SPRITES_TOKEN=
# Alternative: exchange FLY_API_TOKEN for a Sprites token at startup.
SPRITES_ORG=
# SPRITES_API_URL=https://api.sprites.dev
# SPRITE_NAME_PREFIX=prd
SANDBOX_MAX_PER_WORKSPACE=10
# Tigris object storage (optional — requires deploy access approval)
# Billed from actual stored bytes as fractional decimal GB-hours; egress is free.
OBJECT_STORAGE_ENABLED=false
TIGRIS_ACCESS_KEY_ID=
TIGRIS_SECRET_ACCESS_KEY=
TIGRIS_S3_ENDPOINT=https://t3.storage.dev
TIGRIS_IAM_ENDPOINT=https://iam.storageapi.dev
OBJECT_STORAGE_NAME_PREFIX=prd
OBJECT_STORAGE_MAX_BUCKETS_PER_WORKSPACE=10
# Public sandbox API: POST /api/v1/sandboxes with Authorization: Bearer prd_sbx_…
# Create workspace tokens in Deployments → Sandboxes → API tokens (owner only).
# Polar billing (optional — leave POLAR_UNSTATUS_KEY empty to disable billing and usage limits)
# Products (free/basic/pro), meters (events/monitors/members/deploy_*), and benefits are configured
# in the Polar dashboard and tagged with metadata (tier/feature/kind); the API loads that catalog at startup.
# Object storage requires a Polar meter tagged metadata feature=object_storage with a metered unit
# price of 0.002777777777777778 cents per GB-hour ($0.020 per GB-month / 720h).
POLAR_UNSTATUS_KEY=
# Backward-compatible fallback if POLAR_UNSTATUS_KEY is unset.
POLAR_SECRET_KEY=
# POLAR_BASE_URL=https://api.polar.sh
# Secret from the Polar webhook endpoint configured for /api/webhooks/polar.
POLAR_WEBHOOK_SECRET=
# How often (seconds) to re-report monitor/member gauge usage to Polar (default 86400 = daily).
# BILLING_RECONCILE_TICK_SECONDS=86400
# How often (seconds) the resource usage sweep reports deploy/sandbox GB-hours,
# vCPU-hours, volume GB-hours, and object-storage GB-hours to Polar
# (default 900 = 15 min; min 60). Active when billing and at least one resource
# product is enabled.
# DEPLOY_USAGE_SWEEP_TICK_SECONDS=900
# Public app URL for checkout redirects (defaults to first CORS origin if unset)
APP_URL=http://localhost:5173
# Browser hosts that serve the main app, not custom-domain status pages.
VITE_APP_HOSTS=localhost,127.0.0.1,produktive.app,www.produktive.app
# GitHub OAuth login (optional). Configure the GitHub app callback as:
# http://localhost:5173/api/auth/github/callback for Vite dev, or https://your-domain/api/auth/github/callback in prod.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Optional override when the OAuth callback is not APP_URL + /api/auth/github/callback.
GITHUB_REDIRECT_URL=
# SMTP email (optional — leave SMTP_HOST and SMTP_FROM_EMAIL empty to disable transactional email)
SMTP_HOST=
SMTP_PORT=587
# starttls, tls, or none
SMTP_TLS=starttls
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=produktive
RUST_LOG=produktive_api=debug,tower_http=info,sea_orm=warn
