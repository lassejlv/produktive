# Direct connection — used for migrations only.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/produktive
# Pooled connection (e.g. PgBouncer / Neon pooler) — used by the running app.
# Falls back to DATABASE_URL if unset.
DATABASE_POOLED_URL=postgres://postgres:postgres@localhost:5432/produktive
PORT=3000
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
JWT_TTL_HOURS=720
SCHEDULER_TICK_MS=5000
SCHEDULER_MAX_CONCURRENT_CHECKS=32
SCHEDULER_MAX_DUE_PER_TICK=100
HTTP_CHECK_MAX_BODY_BYTES=1048576
REDIS_URL=redis://127.0.0.1/
LOCAL_REGION_SLUG=eu-west
API_LOCAL_WORKER_ENABLED=true
WORKER_TOKEN=change-me-worker-token
# Comma-separated region-scoped worker tokens for external workers, e.g. `us-east=token-1,ap-south=token-2`.
WORKER_TOKENS=
WORKER_LEASE_SECONDS=30
AUTH_RATE_LIMIT_LOGIN_PER_MINUTE=10
AUTH_RATE_LIMIT_REGISTER_PER_HOUR=5
AUTH_RATE_LIMIT_REGISTER_GLOBAL_PER_HOUR=100
# Password reset: per-email and global request caps (per hour), and how long the emailed link stays valid (minutes).
AUTH_RATE_LIMIT_PASSWORD_RESET_PER_HOUR=5
AUTH_RATE_LIMIT_PASSWORD_RESET_GLOBAL_PER_HOUR=100
PASSWORD_RESET_TTL_MINUTES=60
SESSION_CLEANUP_TICK_SECONDS=3600
CUSTOM_DOMAIN_CNAME_TARGET=custom.produktive.app
CUSTOM_DOMAIN_PROXY_IPV4=
CUSTOM_DOMAIN_PROXY_IPV6=
# Comma-separated browser origins allowed to call the API. Leave empty to disable cross-origin browser requests.
CORS_ALLOWED_ORIGINS=http://localhost:5173
# NarrowDB log storage (optional — set BOTH to enable log ingest/search/storage; leave empty to disable logs).
# In production NARROWDB_URL points at the router/gateway, e.g. http://narrowdb-gateway.railway.internal:4747
NARROWDB_URL=
NARROWDB_TOKEN=
# Polar billing (optional — leave POLAR_SECRET_KEY empty to disable billing and usage limits)
# Products (free/basic/pro), meters (events/monitors/members), and benefits are configured in the Polar
# dashboard and tagged with metadata (tier/feature/kind); the API loads that catalog at startup.
POLAR_SECRET_KEY=
# POLAR_BASE_URL=https://api.polar.sh
# Secret from the Polar webhook endpoint configured for /api/webhooks/polar.
POLAR_WEBHOOK_SECRET=
# How often (seconds) to re-report monitor/member gauge usage to Polar (default 86400 = daily).
# BILLING_RECONCILE_TICK_SECONDS=86400
# Public app URL for checkout redirects (defaults to first CORS origin if unset)
APP_URL=http://localhost:5173
# Browser hosts that serve the main app, not custom-domain status pages.
VITE_APP_HOSTS=localhost,127.0.0.1,produktive.app,www.produktive.app
# GitHub OAuth login (optional). Configure the GitHub app callback as:
# http://localhost:5173/api/auth/github/callback for Vite dev, or https://your-domain/api/auth/github/callback in prod.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Optional override when the OAuth callback is not APP_URL + /api/auth/github/callback.
GITHUB_REDIRECT_URL=
# SMTP email (optional — leave SMTP_HOST and SMTP_FROM_EMAIL empty to disable transactional email)
SMTP_HOST=
SMTP_PORT=587
# starttls, tls, or none
SMTP_TLS=starttls
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=produktive
RUST_LOG=produktive_api=debug,tower_http=info,sea_orm=warn
