PORT=3000
DATABASE_URL="postgresql://user:password@localhost:5432/produktive"
DATABASE_DIRECT_URL="postgresql://user:password@localhost:5432/produktive"
JWT_SECRET="replace-with-a-32-character-or-longer-secret"
CORS_ORIGINS="https://produktive.app,https://*.produktive.app,http://localhost:5173,http://127.0.0.1:5173"
AUTH_COOKIE_NAME="produktive_session"
AUTH_COOKIE_DOMAIN=""
AUTH_COOKIE_SECURE=false
AUTH_SESSION_DAYS=30
WEB_DIST_DIR="web/dist"
APP_URL="http://localhost:5173"
MCP_RESOURCE_URL="http://localhost:3001/mcp"
CLOUDFLARE_API_TOKEN="cf_replace-with-your-cloudflare-api-token"
CLOUDFLARE_ACCOUNT_ID="replace-with-your-cloudflare-account-id"
CLOUDFLARE_FROM="Produktive <be@produktive.app>"
AI_API_KEY="replace-with-your-ai-api-key"
AI_BASE_URL="https://ollama.com/v1"
AI_MODEL="kimi-k2.6"
UNKEY_ROOT_KEY="unkey_root_replace-with-your-root-key"
UNKEY_API_ID="api_replace-with-your-api-id"
# UNKEY_BASE_URL="https://api.unkey.com"
# Required only for cargo run -p produktive-api --bin migrate_unkey_keys
# UNKEY_MIGRATION_ID="mig_replace-with-your-unkey-migration-id"
MCP_TOKEN_ENCRYPTION_KEY="replace-with-a-32-character-or-longer-token-encryption-key"
GITHUB_OAUTH_CLIENT_ID=""
GITHUB_OAUTH_CLIENT_SECRET=""
SLACK_CLIENT_ID=""
SLACK_CLIENT_SECRET=""
SLACK_SIGNING_SECRET=""
# Optional. Falls back to MCP_TOKEN_ENCRYPTION_KEY, then JWT_SECRET.
SLACK_TOKEN_ENCRYPTION_KEY=""
S3_ENDPOINT=""
S3_REGION="auto"
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_URL="https://cdn.produktive.app"
